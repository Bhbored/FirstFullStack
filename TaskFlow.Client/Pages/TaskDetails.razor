@page "/task-details/{Id:guid}"
@using TaskFlow.Share.DTO.Response
@using TaskFlow.Share.Enums
@inject HttpClient Client
@inject NavigationManager Navigation

<div class="container mt-4">
    @if (_isLoading)
    {
        <div class="d-flex justify-content-center align-items-center" style="min-height: 400px;">
            <div class="text-center">
                <div class="spinner-border text-primary" role="status" style="width: 3rem; height: 3rem;">
                    <span class="visually-hidden">Loading...</span>
                </div>
                <p class="mt-3 text-muted">Loading task details...</p>
            </div>
        </div>
    }
    else if (showError)
    {
        <div class="alert alert-danger" role="alert">
            <i class="bi bi-exclamation-triangle"></i> @errorMessage
        </div>
    }
    else if (task != null)
    {
        <div class="card">
            <div class="card-header bg-primary text-white">
                <h4><i class="bi bi-card-checklist"></i> Task Details</h4>
            </div>
            <div class="card-body">
                <div class="row g-3">
                    <div class="col-12">
                        <div class="card">
                            <div class="card-header bg-light">
                                <strong><i class="bi bi-info-circle"></i> General Information</strong>
                            </div>
                            <div class="card-body">
                                <div class="row mb-3">
                                    <div class="col-md-3">
                                        <label class="fw-bold text-muted">ID</label>
                                    </div>
                                    <div class="col-md-9">
                                        <span class="text-break">@task.Id</span>
                                    </div>
                                </div>
                                <div class="row mb-3">
                                    <div class="col-md-3">
                                        <label class="fw-bold text-muted">Title</label>
                                    </div>
                                    <div class="col-md-9">
                                        <span>@task.Title</span>
                                    </div>
                                </div>
                                <div class="row mb-3">
                                    <div class="col-md-3">
                                        <label class="fw-bold text-muted">Description</label>
                                    </div>
                                    <div class="col-md-9">
                                        <span>@task.Description</span>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="col-md-6">
                        <div class="card">
                            <div class="card-header bg-light">
                                <strong><i class="bi bi-flag"></i> Priority</strong>
                            </div>
                            <div class="card-body">
                                <span class="badge @GetPriorityBadge(task.Priority)">@task.Priority</span>
                            </div>
                        </div>
                    </div>

                    <div class="col-md-6">
                        <div class="card">
                            <div class="card-header bg-light">
                                <strong><i class="bi bi-check-circle"></i> Status</strong>
                            </div>
                            <div class="card-body">
                                <span class="badge @GetStatusBadge(task.Status)">@task.Status</span>
                            </div>
                        </div>
                    </div>

                    <div class="col-md-6">
                        <div class="card">
                            <div class="card-header bg-light">
                                <strong><i class="bi bi-calendar-event"></i> Due Date</strong>
                            </div>
                            <div class="card-body">
                                <span>@(task.DueDate?.ToString("yyyy-MM-dd HH:mm") ?? "Not set")</span>
                            </div>
                        </div>
                    </div>

                    <div class="col-md-6">
                        <div class="card">
                            <div class="card-header bg-light">
                                <strong><i class="bi bi-clock"></i> Days Left</strong>
                            </div>
                            <div class="card-body">
                                <span class="@(task.DaysLeft <= 0 ? "text-danger fw-bold" : task.DaysLeft <= 3 ? "text-warning fw-bold" : "text-success fw-bold")">
                                    @task.DaysLeft days
                                </span>
                            </div>
                        </div>
                    </div>

                    <div class="col-md-6">
                        <div class="card">
                            <div class="card-header bg-light">
                                <strong><i class="bi bi-calendar-plus"></i> Created Date</strong>
                            </div>
                            <div class="card-body">
                                <span>@(task.CreatedDate?.ToString("yyyy-MM-dd HH:mm") ?? "Not set")</span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="card-footer">
                <button type="button" class="btn btn-secondary" @onclick="GoBack">
                    <i class="bi bi-arrow-left"></i> Back to Tasks
                </button>
            </div>
        </div>
    }
</div>

@code {
    [Parameter]
    public Guid Id { get; set; }

    private TaskResponse? task;
    private bool _isLoading = true;
    private bool showError = false;
    private string errorMessage = "";

    protected override async Task OnInitializedAsync()
    {
        _isLoading = true;
        try
        {
            task = await Client.GetFromJsonAsync<TaskResponse>($"Tasks/{Id}");
            if (task == null)
            {
                showError = true;
                errorMessage = $"No task found with ID: {Id}";
            }
        }
        catch (Exception)
        {
            showError = true;
            errorMessage = $"No task found with ID: {Id}";
        }
        finally
        {
            _isLoading = false;
        }
    }

    private void GoBack()
    {
        Navigation.NavigateTo("/");
    }

    private string GetPriorityBadge(Priority? priority)
    {
        return priority switch
        {
            Priority.Low => "bg-secondary",
            Priority.Meduim => "bg-warning text-dark",
            Priority.High => "bg-danger",
            _ => "bg-secondary"
        };
    }

    private string GetStatusBadge(Status? status)
    {
        return status switch
        {
            Status.PENDING => "bg-warning text-dark",
            Status.Completed => "bg-success",
            _ => "bg-secondary"
        };
    }
}
