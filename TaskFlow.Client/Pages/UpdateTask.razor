@page "/update-task/{Id:guid}"
@using TaskFlow.Share.DTO.Request
@using TaskFlow.Share.DTO.Response
@using TaskFlow.Share.Enums
@inject HttpClient Client
@inject NavigationManager Navigation
@inject ILogger<UpdateTask> _logger

<PageTitle>Update Task</PageTitle>

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card">
                <div class="card-header bg-primary text-white">
                    <h4><i class="bi bi-pencil-square"></i> Update Task</h4>
                </div>
                <div class="card-body">
                    @if (_isLoading)
                    {
                        <div class="d-flex justify-content-center align-items-center" style="min-height: 300px;">
                            <div class="text-center">
                                <div class="spinner-border text-primary" role="status" style="width: 3rem; height: 3rem;">
                                    <span class="visually-hidden">Loading...</span>
                                </div>
                                <p class="mt-3 text-muted">Loading task details...</p>
                            </div>
                        </div>
                    }
                    else if (showError)
                    {
                        <div class="alert alert-danger" role="alert">
                            <i class="bi bi-exclamation-triangle"></i> @errorMessage
                        </div>
                    }
                    else if (updateRequest != null)
                    {
                        <EditForm Model="updateRequest" OnValidSubmit="HandleUpdate">
                            <DataAnnotationsValidator />

                            <div class="mb-3">
                                <label for="title" class="form-label">Title <span class="text-danger">*</span></label>
                                <input type="text" id="title" class="form-control" @bind="updateRequest.Title" />
                                <ValidationMessage For="@(() => updateRequest.Title)" class="text-danger" />
                            </div>

                            <div class="mb-3">
                                <label for="description" class="form-label">Description</label>
                                <textarea id="description" class="form-control" rows="4" @bind="updateRequest.Description"></textarea>
                                <ValidationMessage For="@(() => updateRequest.Description)" class="text-danger" />
                            </div>

                            <div class="row">
                                <div class="col-md-6 mb-3">
                                    <label for="priority" class="form-label">Priority</label>
                                    <select id="priority" class="form-select" @bind="updateRequest.Priority">
                                        @foreach (var priority in Enum.GetValues<Priority>())
                                        {
                                            <option value="@priority">@priority</option>
                                        }
                                    </select>
                                    <ValidationMessage For="@(() => updateRequest.Priority)" class="text-danger" />
                                </div>

                                <div class="col-md-6 mb-3">
                                    <label for="status" class="form-label">Status</label>
                                    <select id="status" class="form-select" @bind="updateRequest.Status">
                                        @foreach (var status in Enum.GetValues<Status>())
                                        {
                                            <option value="@status">@status</option>
                                        }
                                    </select>
                                    <ValidationMessage For="@(() => updateRequest.Status)" class="text-danger" />
                                </div>
                            </div>

                            <div class="mb-3">
                                <label for="dueDate" class="form-label">Due Date <span class="text-danger">*</span></label>
                                <input type="datetime-local" id="dueDate" class="form-control" @bind="updateRequest.DueDate" />
                                <ValidationMessage For="@(() => updateRequest.DueDate)" class="text-danger" />
                            </div>

                            <div class="d-flex justify-content-between">
                                <button type="button" class="btn btn-secondary" @onclick="GoBack">
                                    <i class="bi bi-arrow-left"></i> Cancel
                                </button>
                                <button type="submit" class="btn btn-primary" disabled="@(_isSubmitting)">
                                    <span class="spinner-border spinner-border-sm me-2" role="status" aria-hidden="true" style="display: @(_isSubmitting ? "inline-block" : "none")"></span>
                                    <i class="bi bi-check-circle"></i> Update
                                </button>
                            </div>
                        </EditForm>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    [Parameter]
    public Guid Id { get; set; }

    private TaskUpdateRequest? updateRequest;
    private bool _isLoading = true;
    private bool _isSubmitting = false;
    private bool showError = false;
    private string errorMessage = "";

    protected override async Task OnInitializedAsync()
    {
        _isLoading = true;
        try
        {
            var task = await Client.GetFromJsonAsync<TaskResponse>($"Tasks/{Id}");
            if (task == null)
            {
                showError = true;
                errorMessage = $"No task found with ID: {Id}";
            }
            else
            {
                updateRequest = new TaskUpdateRequest
                {
                    Id = task.Id,
                    Title = task.Title,
                    Description = task.Description,
                    Priority = task.Priority,
                    DueDate = task.DueDate,
                    Status = task.Status
                };
            }
        }
        catch (HttpRequestException ex)
        {
            showError = true;
            errorMessage = "Could'nt connect to the server";
            _logger.LogInformation(ex.Message);
        }
        catch (Exception)
        {
            showError = true;
            errorMessage = $"No task found with ID: {Id}";
        }
        finally
        {
            _isLoading = false;
        }
    }

    private void GoBack()
    {
        Navigation.NavigateTo("/");
    }

    private async Task HandleUpdate()
    {
        _isSubmitting = true;
        try
        {

            if (updateRequest != null)
            {
                var response = await Client.PutAsJsonAsync<TaskUpdateRequest>("Tasks/update", updateRequest);
                if (response.IsSuccessStatusCode)
                    Navigation.NavigateTo("/");
            }
        }
        catch (HttpRequestException ex)
        {
            showError = true;
            errorMessage = "Could'nt connect to the server";
            _logger.LogInformation(ex.Message);
        }
        catch (Exception)
        {
            showError = true;
            errorMessage = $"No task found with ID: {Id}";
        }
        finally
        {
            _isSubmitting = false;
        }
    }
}
